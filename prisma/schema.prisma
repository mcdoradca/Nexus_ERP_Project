generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- NOWE SŁOWNIKI KONTROLI DOSTĘPU (RBAC) ---
enum UserGroup {
  PRACOWNICY
  GOSC
  AGENCJE
}

enum Department {
  MARKETING
  BIURO
  MAGAZYN
  HANDLOWCY
  KAM
  PREZES
  ECOMMERCE
  SERWIS
  BRAK 
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     // Zahaszowane hasło
  name         String   
  group        UserGroup  @default(PRACOWNICY)
  department   Department @default(BRAK)
  role         String     @default("USER") // ADMIN lub USER
  color        String   
  isActive     Boolean    @default(true)
  isOnline     Boolean    @default(false)
  lastSeen     DateTime   @default(now())
  createdAt    DateTime   @default(now())

  assignedTasks Task[]    @relation("TaskAssignees")
  createdTasks  Task[]    @relation("TaskCreator")
  comments      Comment[] 
  globalMessages GlobalMessage[]
  notifications  Notification[]
  
  // Relacje dla wiadomości prywatnych (Direct Messages)
  sentDirectMessages     DirectMessage[] @relation("SentDirectMessages")
  receivedDirectMessages DirectMessage[] @relation("ReceivedDirectMessages")

  // NOWOŚĆ: Śledzenie kto aktualnie pracuje nad jakim zadaniem (Focus Mode)
  activeTaskId  String?
  activeTask    Task?           @relation("ActiveWorker", fields: [activeTaskId], references: [id])
}

model Project {
  id          String     @id @default(uuid())
  name        String   
  description String?  
  progress    Int        @default(0) 
  color       String   
  startDate   DateTime?
  endDate     DateTime?
  isArchived  Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tasks       Task[]
}

enum TaskStatus { 
  TODO
  IN_PROGRESS
  REVIEW
  DONE 
}

enum TaskPriority { 
  LOW
  MEDIUM
  HIGH 
}

model Task {
  id          String       @id @default(uuid())
  taskId      String       @unique @default(dbgenerated("generate_task_id()"))
  title       String       
  description String?      @db.Text 
  status      TaskStatus   @default(TODO) 
  priority    TaskPriority @default(MEDIUM)
  startDate   DateTime?
  dueDate     DateTime?    
  
  // NOWOŚĆ: Blokady i Focus
  isBlocked   Boolean      @default(false)
  blockReason String?      @db.Text
  activeWorkers User[]     @relation("ActiveWorker")
  
  projectId   String?
  campaignId  String?      // Zadanie może być opcjonalnie podpięte pod Kampanię
  creatorId   String       

  project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  campaign    Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  assignees   User[]       @relation("TaskAssignees")
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [id])
  comments    Comment[]    

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([projectId])
  @@index([campaignId])
}

model Comment {
  id         String   @id @default(uuid())
  content    String   @db.Text 
  actionType String   @default("message") 
  fileUrl    String?  // Link do pliku w Supabase Storage
  fileName   String?  // Oryginalna nazwa pliku
  taskId     String
  authorId   String

  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author     User     @relation(fields: [authorId], references: [id])
  createdAt  DateTime @default(now()) 

  @@index([taskId])
}

model GlobalMessage {
  id        String   @id @default(uuid())
  content   String   @db.Text
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("info") // "task_new", "deadline", "idle"
  isRead    Boolean  @default(false)
  taskId    String?  
  relatedTaskId String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model DirectMessage {
  id         String   @id @default(uuid())
  content    String   @db.Text
  actionType String   @default("message") 
  fileUrl    String?  
  fileName   String?  
  isRead     Boolean  @default(false)
  
  senderId   String
  receiverId String
  
  sender     User     @relation("SentDirectMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedDirectMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@index([senderId, receiverId])
  @@index([receiverId, senderId])
}

// NOWOŚĆ: Zaawansowany model Kampanii Marketingowych
model Campaign {
  id          String   @id @default(uuid())
  name        String
  description String?
  budget      Float    @default(0.0)
  targetSKUs  String?  // Wypisane z palca, np. "CeraVe SA, Vichy Min 89"
  networks    String?  // Kanały dystrybucji, np. "Allegro, Hebe, Notino"
  startDate   DateTime
  endDate     DateTime
  status      String   @default("Planowana") // Planowana, W trakcie, Zakończona, Zablokowana
  color       String   @default("bg-pink-500")
  
  tasks       Task[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Brand {
  id          String    @id @default(uuid())
  name        String    @unique
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Product {
  id                    String   @id @default(uuid())
  ean                   String   @unique // Kod kreskowy - główny identyfikator
  sku                   String   @unique
  name                  String
  stock                 Int      @default(0)
  salePrice             Float    @default(0.0) // Cena sprzedaży
  
  // UNIT ECONOMICS (Koszty zmienne przypisane do 1 sztuki)
  basePrice             Float    @default(0.0) // Cena zakupu
  inboundTransportCost  Float    @default(0.0) // Transport do firmy, cła
  packagingCost         Float    @default(0.0) // Karton, pakowanie
  bdoEprCost            Float    @default(0.0) // Podatki BDO / śmieci
  outboundTransportCost Float    @default(0.0) // Transport do klienta
  
  status                String   @default("Aktywny") 
  
  // INTEGRACJE (Gotowość na synchronizację API)
  subiektId             String?  @unique // ID z bazy MS SQL Subiekt GT
  baselinkerId          String?  @unique // ID z bazy Baselinker
  isSynced              Boolean  @default(false)
  
  brandId               String
  brand                 Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([brandId])
  @@index([sku])
  @@index([ean])
}

