generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String             @id @default(uuid())
  email                  String             @unique
  name                   String
  role                   String             @default("USER")
  color                  String
  isActive               Boolean            @default(true)
  createdAt              DateTime           @default(now())
  department             Department         @default(BRAK)
  group                  UserGroup          @default(PRACOWNICY)
  isOnline               Boolean            @default(false)
  lastSeen               DateTime           @default(now())
  passwordHash           String
  activeTaskId           String?
  accessibleModules      String[]           @default(["kanban", "campaigns", "projects", "products", "chat"])
  authoredAnnouncements  Announcement[]
  readAnnouncements      AnnouncementRead[]
  uploadedAssets         CampaignAsset[]
  assignedCampaigns      Campaign[]         @relation("CampaignAssignees")
  comments               Comment[]
  receivedDirectMessages DirectMessage[]    @relation("ReceivedDirectMessages")
  sentDirectMessages     DirectMessage[]    @relation("SentDirectMessages")
  globalMessages         GlobalMessage[]
  notifications          Notification[]
  ownedProjects          Project[]          @relation("ProjectOwner")
  managedProjects        Project[]          @relation("ProjectManager")
  blockingTasks          Task[]             @relation("TaskBlocker")
  createdTasks           Task[]             @relation("TaskCreator")
  ownedTasks             Task[]             @relation("TaskOwner")
  activeTask             Task?              @relation("ActiveWorker", fields: [activeTaskId], references: [id])
  assignedTasks          Task[]             @relation("TaskAssignees")
}

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  progress    Int       @default(0)
  isArchived  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  endDate     DateTime?
  startDate   DateTime?
  budget      Float     @default(0.0)
  ownerId     String?
  pmId        String?
  color       String    @default("bg-emerald-500")
  status      String    @default("AKTYWNY")
  comments    Comment[]
  owner       User?     @relation("ProjectOwner", fields: [ownerId], references: [id])
  pm          User?     @relation("ProjectManager", fields: [pmId], references: [id])
  tasks       Task[]
}

model Task {
  id             String       @id @default(uuid())
  taskId         String       @unique @default(dbgenerated("generate_task_id()"))
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  projectId      String?
  creatorId      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  startDate      DateTime?
  blockReason    String?
  campaignId     String?
  isBlocked      Boolean      @default(false)
  blockerId      String?
  estimatedHours Float        @default(0.0)
  loggedHours    Float        @default(0.0)
  ownerId        String?
  parentTaskId   String?
  assignedGroups String[]     @default([])
  isArchived     Boolean      @default(false)
  comments       Comment[]
  blocker        User?        @relation("TaskBlocker", fields: [blockerId], references: [id])
  campaign       Campaign?    @relation(fields: [campaignId], references: [id])
  creator        User         @relation("TaskCreator", fields: [creatorId], references: [id])
  owner          User?        @relation("TaskOwner", fields: [ownerId], references: [id])
  parentTask     Task?        @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks       Task[]       @relation("SubTasks")
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activeWorkers  User[]       @relation("ActiveWorker")
  assignees      User[]       @relation("TaskAssignees")

  @@index([status])
  @@index([projectId])
  @@index([campaignId])
}

model Comment {
  id         String    @id @default(uuid())
  content    String
  actionType String    @default("message")
  taskId     String?
  authorId   String
  createdAt  DateTime  @default(now())
  fileName   String?
  fileUrl    String?
  campaignId String?
  projectId  String?
  author     User      @relation(fields: [authorId], references: [id])
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task       Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([projectId])
  @@index([campaignId])
}

model GlobalMessage {
  id         String   @id @default(uuid())
  content    String
  authorId   String
  createdAt  DateTime @default(now())
  actionType String   @default("message")
  fileName   String?
  fileUrl    String?
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model Notification {
  id            String   @id @default(uuid())
  userId        String
  title         String
  message       String
  type          String   @default("info")
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
  taskId        String?
  relatedTaskId String?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DirectMessage {
  id         String   @id @default(uuid())
  content    String
  isRead     Boolean  @default(false)
  senderId   String
  receiverId String
  createdAt  DateTime @default(now())
  actionType String   @default("message")
  fileName   String?
  fileUrl    String?
  receiver   User     @relation("ReceivedDirectMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentDirectMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, senderId])
}

model Announcement {
  id         String             @id @default(uuid())
  title      String
  content    String
  priority   String             @default("NORMAL")
  isRequired Boolean            @default(true)
  authorId   String
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  author     User               @relation(fields: [authorId], references: [id])
  reads      AnnouncementRead[]
}

model AnnouncementRead {
  id             String       @id @default(uuid())
  userId         String
  announcementId String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId])
}

model Campaign {
  id               String            @id @default(uuid())
  name             String
  description      String?
  budget           Float             @default(0.0)
  networks         String?
  startDate        DateTime
  endDate          DateTime
  status           String            @default("Planowana")
  color            String            @default("bg-blue-500")
  assignees        User[]            @relation("CampaignAssignees")
  assignedGroups   String[]          @default([])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  budgetAgency     Float             @default(0.0)
  budgetMedia      Float             @default(0.0)
  budgetPOSM       Float             @default(0.0)
  markets          String?
  brandId          String?
  instructions     String?
  plannedCount     Int               @default(0)
  productId        String?
  soldCount        Int               @default(0)
  brand            Brand?            @relation(fields: [brandId], references: [id])
  product          Product?          @relation("CampaignPromotedProduct", fields: [productId], references: [id])
  assets           CampaignAsset[]
  campaignProducts CampaignProduct[]
  comments         Comment[]
  tasks            Task[]
  smiPosts         SmiPost[]
}

model Brand {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  campaigns Campaign[]
  products  Product[]
}

model CampaignProduct {
  id             String   @id @default(uuid())
  campaignId     String
  productId      String
  promoMechanic  String?
  posmAllocation Int      @default(0)
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([campaignId, productId])
}

model CampaignAsset {
  id         String   @id @default(uuid())
  campaignId String
  uploaderId String
  name       String
  fileUrl    String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  uploader   User     @relation(fields: [uploaderId], references: [id])
}

model Product {
  id                    String            @id @default(uuid())
  ean                   String            @unique
  sku                   String            @unique
  name                  String
  stock                 Int               @default(0)
  salePrice             Float             @default(0.0)
  basePrice             Float             @default(0.0)
  inboundTransportCost  Float             @default(0.0)
  packagingCost         Float             @default(0.0)
  bdoEprCost            Float             @default(0.0)
  outboundTransportCost Float             @default(0.0)
  status                String            @default("Aktywny")
  subiektId             String?           @unique
  baselinkerId          String?           @unique
  isSynced              Boolean           @default(false)
  brandId               String
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  campaignsAsMain       Campaign[]        @relation("CampaignPromotedProduct")
  campaignProducts      CampaignProduct[]
  brand                 Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([sku])
  @@index([ean])
}

enum UserGroup {
  PRACOWNICY
  GOSC
  AGENCJE
}

enum Department {
  MARKETING
  BIURO
  MAGAZYN
  HANDLOWCY
  KAM
  PREZES
  ECOMMERCE
  SERWIS
  BRAK
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SmiPost {
  id              String   @id @default(uuid())
  campaignId      String
  brandLine       String?
  publishDate     DateTime
  postType        String?  
  content         String?  @db.Text
  hashtags        String?  @db.Text
  hasGraphics     Boolean  @default(false)
  notes           String?  @db.Text
  redirectUrl     String?  
  adBudgetInfo    String?  
  status          String   @default("Szkic") 
  mediaUrls       String[] @default([])
  mediaTypes      String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model Company {
  id          String   @id @default(uuid())
  taxId       String?  @unique // NIP
  regon       String?
  krs         String?
  name        String
  legalForm   String?  // np. "Sp. z o.o."
  industry    String?  
  website     String?
  mainPhone   String?
  mainEmail   String?
  status      String   @default("Aktywny") // Aktywny, Zablokowany, Prospekt
  rating      Int?     @default(0)         // 1-5 gwiazdek
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branches    CompanyBranch[]
  contacts    ContactPerson[]
}

model CompanyBranch {
  id             String   @id @default(uuid())
  companyId      String
  name           String   // np. "Magazyn Główny", "Siedziba"
  type           String   @default("Oddział") // Siedziba, Magazyn, Sklep, Biuro
  street         String?
  building       String?
  city           String?
  postalCode     String?
  country        String   @default("Polska")
  isHeadquarters Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contacts       ContactPerson[]
  
  @@index([companyId])
}

model ContactPerson {
  id          String   @id @default(uuid())
  companyId   String
  branchId    String?
  firstName   String
  lastName    String
  role        String?  // Dyrektor, Księgowość, Handlowiec
  phone       String?
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch      CompanyBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([branchId])
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
